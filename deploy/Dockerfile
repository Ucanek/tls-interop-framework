FROM fedora:39

# Install dependencies (nss-tools for NSS wrapper)
RUN dnf install -y python3 python3-pip openssl gnutls-utils nss-tools socat coreutils && dnf clean all
# Must stay >= GRPC_GENERATED_VERSION in proto/interop_pb2_grpc.py (regenerated by grpcio-tools).
RUN pip3 install 'grpcio>=1.80.0' 'grpcio-tools>=1.80.0' 'protobuf>=4.21'

WORKDIR /app

# Schema + generated protobuf/gRPC Python (regenerate with ./scripts/run.sh protoc)
COPY proto/ ./proto/
# Copy wrappers, driver, and NSS DB setup script
COPY src/wrappers/wrapper_common.py src/wrappers/wrapper_openssl.py src/wrappers/wrapper_gnutls.py src/wrappers/wrapper_nss.py ./
COPY src/driver/driver.py ./
COPY deploy/wrapper_launch.sh ./wrapper_launch.sh
COPY scripts/setup_nssdb.sh ./
RUN chmod +x wrapper_launch.sh setup_nssdb.sh
# Generate certificates and NSS DB (for wrapper_nss.py)
RUN openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -sha256 -days 365 -nodes -subj "/CN=server_node" \
  && NSSDB=/app/nssdb ./setup_nssdb.sh

# Control port for gRPC, Data port for TLS
EXPOSE 50051
EXPOSE 5555

CMD ["python3", "wrapper_openssl.py"]